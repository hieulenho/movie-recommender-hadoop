# Maven and Java build output
target/
*.class
*.jar
*.war
*.ear

# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.streamlit/cache/

# Virtual environments
.venv/
.venv-demo/
venv/
env/
ENV/

# IDE and editor configuration
.idea/
.vscode/
.settings/
.project
.classpath
*.iml

# Logs
*.log
logs/

# Environment and secret files
.env
.env.*
!.env.example
*.pem
*.key
secrets/

# Operating-system generated files
.DS_Store
Thumbs.db
desktop.ini

